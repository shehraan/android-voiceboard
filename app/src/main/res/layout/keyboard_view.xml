<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="8dp">

    <!-- Preview text area -->
    <TextView
        android:id="@+id/previewText"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:visibility="invisible"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="18sp"
        android:textColor="#333333"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Mic button - center, top row, moved up 50dp -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-50dp"
        android:layout_marginBottom="12dp">
        
        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:src="@drawable/ic_mic_2d"
            android:contentDescription="Microphone"
            android:background="@drawable/mic_button_ripple"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:elevation="4dp"
            android:layout_gravity="center" />
            
    </FrameLayout>

    <!-- Controls row - all non-mic buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:background="#E0E0E0"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:layout_marginEnd="16dp" />

        <!-- Mode toggle button -->
        <Button
            android:id="@+id/modeToggleButton"
            android:layout_width="68dp"
            android:layout_height="54dp"
            android:text="Raw"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:contentDescription="Toggle mode"
            android:background="#757575"
            android:layout_marginEnd="16dp" />

        <!-- Backspace button -->
        <Button
            android:id="@+id/backspaceButton"
            android:layout_width="56dp"
            android:layout_height="54dp"
            android:text="⌫"
            android:textSize="22sp"
            android:contentDescription="Backspace"
            android:background="#E0E0E0"
            android:layout_marginEnd="8dp" />

    </LinearLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#666666"
        android:minHeight="20dp"
        android:layout_marginTop="4dp" />

</LinearLayout>
