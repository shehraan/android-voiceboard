<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="8dp">

    <!-- Preview text area -->
    <TextView
        android:id="@+id/previewText"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:visibility="invisible"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="18sp"
        android:textColor="#333333"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Controls row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:background="#E0E0E0"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:layout_marginEnd="8dp" />

        <!-- Mode toggle button -->
        <Button
            android:id="@+id/modeToggleButton"
            android:layout_width="72dp"
            android:layout_height="60dp"
            android:text="RAW"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:contentDescription="Toggle mode"
            android:background="#757575"
            android:layout_marginEnd="16dp" />

        <!-- Mic button (circular) -->
        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_mic_2d"
            android:contentDescription="Microphone"
            android:background="@drawable/mic_button_circle"
            android:padding="16dp"
            android:scaleType="centerInside"
            android:layout_marginEnd="16dp" />

        <!-- Backspace button -->
        <Button
            android:id="@+id/backspaceButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="⌫"
            android:textSize="24sp"
            android:contentDescription="Backspace"
            android:background="#E0E0E0"
            android:layout_marginEnd="8dp" />

    </LinearLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="#666666"
        android:minHeight="24dp"
        android:layout_marginTop="4dp" />

</LinearLayout>
